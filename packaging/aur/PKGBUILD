# Maintainer: Gustavo <your-email@example.com>
pkgname=watui
pkgver=0.2.0
pkgrel=1
pkgdesc="Terminal UI client for WhatsApp built with Go + Bubble Tea + whatsmeow"
arch=('x86_64' 'aarch64')
url="https://github.com/Guistoff081/watui"
license=('MIT')
depends=('glibc')
makedepends=('go>=1.24' 'gcc' 'git')
source=("${pkgname}-${pkgver}.tar.gz::${url}/archive/refs/tags/v${pkgver}.tar.gz")
b2sums=('SKIP')

prepare() {
    cd "${pkgname}-${pkgver}"
    # download Go module dependencies
    go mod download
}

build() {
    cd "${pkgname}-${pkgver}"
    export CGO_ENABLED=1
    export CGO_CPPFLAGS="${CPPFLAGS}"
    export CGO_CFLAGS="${CFLAGS}"
    export CGO_CXXFLAGS="${CXXFLAGS}"
    export CGO_LDFLAGS="${LDFLAGS}"
    export GOFLAGS="-buildmode=pie -trimpath -mod=readonly -modcacherw"

    go build \
        -ldflags "-X main.version=v${pkgver} -X main.commit=release -s -w" \
        -o "${pkgname}" \
        ./cmd/watui/
}

check() {
    cd "${pkgname}-${pkgver}"
    go test ./...
}

package() {
    cd "${pkgname}-${pkgver}"
    install -Dm755 "${pkgname}" "${pkgdir}/usr/bin/${pkgname}"
    install -Dm644 LICENSE "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE"
    install -Dm644 README.md "${pkgdir}/usr/share/doc/${pkgname}/README.md"
}
